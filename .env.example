# Database (Supabase Postgres)
# Transaction pooler (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20"
# Session pooler (port 5432) — used by prisma migrate / db pull. Prefer this over db.[PROJECT].supabase.co if direct host DNS fails.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Storage (server-side only for uploads)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth (generate your own random string; not from Supabase JWT Keys page)
JWT_SECRET="please-change-me-in-production-jewelflow-secret-key"
JWT_EXPIRES_IN="30m"
SA_IMPERSONATION_SECRET="generate-a-different-secret-here"

# App base URL (server-side emails; set per environment — never commit production secrets here)
# Local: copy to .env.local → APP_URL=http://localhost:3000
APP_URL="http://localhost:3000"
# Production (Vercel): APP_URL=https://jewlleryweb-app-multi-tenant-arc.vercel.app
# Optional legacy fallback: NEXT_PUBLIC_APP_URL
NODE_ENV="development"

# Email (Gmail SMTP via Nodemailer — use a Gmail App Password, not your login password)
EMAIL_PROVIDER="nodemailer"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="chota.ustaad04@gmail.com"
SMTP_PASS="your-gmail-app-password"
EMAIL_FROM="JewelFlow <chota.ustaad04@gmail.com>"
PASSWORD_RESET_TTL_MINUTES="30"

# Local dev: log reset/setup URLs instead of sending email (never use in production)
DEV_SKIP_EMAIL="true"

# Optional: Resend provider (set EMAIL_PROVIDER=resend)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# RESEND_FROM_EMAIL="JewelFlow <onboarding@resend.dev>"

# Rate limiting (Upstash Redis — https://upstash.com)
# When unset, rate limits are skipped (local dev). Required in production.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
